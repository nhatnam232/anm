# Supabase - browser safe (protected by Row Level Security)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key

# Supabase - server only, NEVER prefix with VITE_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional automatic translation service (LibreTranslate-compatible)
LIBRETRANSLATE_URL=https://your-libretranslate-instance
LIBRETRANSLATE_API_KEY=your-api-key

# DeepL API (recommended - 500k chars/month free)
# Get key at: https://www.deepl.com/pro#developer
# Free tier keys end with ":fx"  →  uses api-free.deepl.com automatically
DEEPL_API_KEY=your-deepl-auth-key:fx
