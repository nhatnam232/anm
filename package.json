{
  "name": "anime-wiki",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "client:dev": "vite",
    "build": "tsc -b && vite build",
    "build:prerender": "tsc -b && vite build && tsx scripts/prerender.ts",
